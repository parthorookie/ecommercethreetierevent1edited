# terraform/terraform.tfvars.example
# Copy to terraform.tfvars and fill in values
# DO NOT commit terraform.tfvars — it is gitignored

region       = "ap-south-1"
project_name = "ecommerce"
environment  = "prod"

# Set via GitHub Actions secret: DB_PASSWORD
# db_password = "CHANGE_ME"

vpc_cidr             = "10.0.0.0/16"
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnet_cidrs = ["10.0.3.0/24", "10.0.4.0/24"]
availability_zones   = ["ap-south-1a", "ap-south-1b"]

rabbitmq_instance_type = "t3.medium"
# Amazon Linux 2023 in ap-south-1 (update to latest)
rabbitmq_ami = "ami-0f58b397bc5c1f2e8"

eks_node_instance_types = ["t3.medium"]
eks_desired_size        = 2
eks_min_size            = 1
eks_max_size            = 5
