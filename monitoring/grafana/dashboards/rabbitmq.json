{
  "title": "RabbitMQ — Live Queue Dashboard",
  "uid": "rabbitmq-ecommerce",
  "timezone": "browser",
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "📦 Main Queue Depth (orders)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rabbitmq_queue_messages{queue=\"orders\"}",
          "legendFormat": "Queue Depth",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red",    "value": 100 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "🚨 DLQ Size (orders.dlq)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "rabbitmq_queue_messages{queue=\"orders.dlq\"}",
          "legendFormat": "DLQ",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1 }
            ]
          },
          "mappings": [{ "type": "value", "value": "0", "result": { "text": "Clean ✅" } }]
        }
      }
    },
    {
      "id": 3,
      "title": "🅿️ Parking Lot (poison messages)",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "rabbitmq_queue_messages{queue=\"orders.parking-lot\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green",  "value": null },
              { "color": "orange", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "🔁 Retry 5s Queue",
      "type": "stat",
      "gridPos": { "x": 12, "y": 4, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "rabbitmq_queue_messages{queue=\"orders.retry.5s\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "🔁 Retry 30s Queue",
      "type": "stat",
      "gridPos": { "x": 18, "y": 4, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "rabbitmq_queue_messages{queue=\"orders.retry.30s\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "📈 Message Rate (msgs/sec)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(rabbitmq_queue_messages_published_total{queue=\"orders\"}[1m])",
          "legendFormat": "Publish rate",
          "refId": "A"
        },
        {
          "expr": "rate(rabbitmq_queue_messages_delivered_total{queue=\"orders\"}[1m])",
          "legendFormat": "Consume rate",
          "refId": "B"
        }
      ]
    },
    {
      "id": 7,
      "title": "👷 Active Consumers",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "rabbitmq_queue_consumers{queue=\"orders\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green",  "value": 2 }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "All Queues — Message Count",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "rabbitmq_queue_messages",
          "legendFormat": "{{ queue }}",
          "refId": "A"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    }
  ]
}
